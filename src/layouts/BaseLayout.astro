---
import "@styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  includeStructuredData?: boolean;
}

const {
  title,
  description,
  canonicalPath = "/",
  canonicalUrl,
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  includeStructuredData = false
} = Astro.props;

const siteUrl = "https://who-holds-the-camera.pages.dev";
const normalizedPath = canonicalPath.startsWith("/") ? canonicalPath : `/${canonicalPath}`;
const resolvedCanonicalUrl = canonicalUrl ?? `${siteUrl}${normalizedPath}`;
const ogImage = `${siteUrl}/og-image.svg`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": ["CreativeWork", "WebSite"],
  name: "Who Holds the Camera? 西方镜头中的中国",
  alternateName: "China Through Other Lenses",
  description,
  url: resolvedCanonicalUrl,
  inLanguage: "zh-CN",
  creator: {
    "@type": "Person",
    name: "Conan Xin"
  },
  about: [
    { "@type": "Thing", name: "photography" },
    { "@type": "Thing", name: "archives" },
    { "@type": "Thing", name: "China" },
    { "@type": "Thing", name: "visual culture" },
    { "@type": "Thing", name: "digital exhibition" }
  ]
};

const structuredDataAsString = JSON.stringify(structuredData, null, 2);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    {includeStructuredData && <script type="application/ld+json" set:html={structuredDataAsString} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
