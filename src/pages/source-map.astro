---
import ArchiveGraph from "@components/ArchiveGraph.astro";
import SourceFlow from "@components/SourceFlow.astro";
import SourceLegend from "@components/SourceLegend.astro";
import SourceMapHero from "@components/SourceMapHero.astro";
import SourceNodeCard from "@components/SourceNodeCard.astro";
import SourceStats from "@components/SourceStats.astro";
import {
  gallerySourceFlows,
  sourceEdges,
  sourceNodes,
  sourceStats,
  sourceTypeOrder
} from "@data/sourceMap";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "来源地图：图像如何抵达本展 / Source Map";
const pageDescription =
  "展示本展中图像线索如何从档案馆、博物馆、摄影师项目、二级视觉线索进入线上展览的来源地图。";
const groupedNodes = sourceTypeOrder.map((sourceType) => ({
  sourceType,
  nodes: sourceNodes.filter((node) => node.sourceType === sourceType)
}));
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <SourceMapHero stats={sourceStats} />
    <div class="page-shell page-shell--source-map">
      <SourceStats stats={sourceStats} />
      <ArchiveGraph nodes={sourceNodes} edges={sourceEdges} />
      <SourceFlow flows={gallerySourceFlows} nodes={sourceNodes} />

      <section class="source-node-section" id="source-node-cards" aria-labelledby="source-node-cards-title">
        <div class="section-heading section-heading--compact">
          <p class="section-kicker">Source Node Cards / 来源节点</p>
          <h2 id="source-node-cards-title">来源机构如何被本展使用</h2>
        </div>
        <div class="source-node-section__groups">
          {
            groupedNodes.filter((group) => group.nodes.length).map((group) => (
              <section class="source-node-group" aria-label={group.sourceType}>
                <h3>{group.sourceType}</h3>
                <div class="source-node-group__grid">
                  {group.nodes.map((node) => <SourceNodeCard node={node} />)}
                </div>
              </section>
            ))
          }
        </div>
      </section>

      <SourceLegend />

      <nav class="source-map-backlinks" aria-label="Source map links">
        <a href="/">返回首页</a>
        <a href="/#source-index">返回 Source Index</a>
        <a href="/#archive-table">查看 Archive Table</a>
      </nav>

      <footer class="site-footer" aria-label="Project links">
        <p>Who Holds the Camera? / V1.7 Source Map</p>
        <nav>
          <a href="https://who-holds-the-camera.pages.dev/" target="_blank" rel="noreferrer">Live Demo</a>
          <a href="https://github.com/conanxin/who-holds-the-camera" target="_blank" rel="noreferrer">GitHub Repo</a>
        </nav>
      </footer>
    </div>
  </main>
</BaseLayout>
