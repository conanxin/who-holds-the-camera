---
import ArchiveTable from "@components/ArchiveTable.astro";
import CuratorStatement from "@components/CuratorStatement.astro";
import ExhibitionEntrance from "@components/ExhibitionEntrance.astro";
import ExhibitionRoutes from "@components/ExhibitionRoutes.astro";
import GalleryMap from "@components/GalleryMap.astro";
import GalleryPreview from "@components/GalleryPreview.astro";
import Lightbox from "@components/Lightbox.astro";
import SourceIndex from "@components/SourceIndex.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { exhibitionRoutes, galleries } from "@data/exhibition";
import { objects } from "@data/objects";
import { sourceStats } from "@data/sourceMap";
import { sources } from "@data/sources";

const heroObjects = objects.filter((object) => object.imagePolicy === "embed").slice(0, 7);
const objectsByGallery = galleries.map((gallery) => ({
  gallery,
  objects: objects.filter((object) => object.galleryId === gallery.id)
}));
const pageTitle = "Who Holds the Camera? 西方镜头中的中国";
const pageDescription =
  "一个关于摄影、权力、记忆与“China”视觉建构的中文线上展览。以 Flashbak 等视觉线索为入口，持续追溯档案馆、博物馆、摄影师项目和公共资料库的原始记录。";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/"
  includeStructuredData={true}
>
  <main>
    <ExhibitionEntrance heroObjects={heroObjects} />
    <div class="page-shell">
      <CuratorStatement />
      <GalleryMap galleries={galleries} />
      <ExhibitionRoutes routes={exhibitionRoutes} />
      {objectsByGallery.map(({ gallery, objects }) => <GalleryPreview gallery={gallery} objects={objects} />)}

      <section class="reflection-room" id="reflection-room" aria-labelledby="reflection-title">
        <div class="section-heading">
          <p class="section-kicker">Reflection Room / 结语</p>
          <h2 id="reflection-title">反思不是反面，而是问题意识</h2>
        </div>
        <div class="reflection-room__panel">
          <p class="reflection-room__lead">
            图片不是“证据”的单向陈列。图像的可见性与缺席同样塑造阅读条件。
          </p>
          <div class="reflection-room__grid">
            <p>
              我们不是把问题投射给对象本身，而是追问观看位置：谁拍了它，谁命名了它，谁保留了它，谁被排除在叙事之外。
            </p>
            <p>
              这就是这组 Source Trail 与 Source Map 的意义。图像不是最终答案，而是让展览把“看见”变成一项可追问的历史实践。
            </p>
          </div>
        </div>
      </section>

      <section class="source-map-entry" id="source-map-entry" aria-labelledby="source-map-entry-title">
        <div class="section-heading section-heading--compact">
          <p class="section-kicker">Source Map / 来源地图</p>
          <h2 id="source-map-entry-title">查看来源地图</h2>
        </div>
        <div class="source-map-entry__panel">
          <p>
            了解本展图像如何从档案、馆藏、摄影师项目和二级视线线索进入，并如何在展品层次中被重新组织。Source Map 页面解释来源路径与关系。
          </p>
          <dl>
            <div>
              <dt>Objects</dt>
              <dd>{sourceStats.totalObjects}</dd>
            </div>
            <div>
              <dt>Source groups</dt>
              <dd>{sourceStats.sourceGroups}</dd>
            </div>
            <div>
              <dt>Rights unclear</dt>
              <dd>{sourceStats.statusCounts["rights unclear"]}</dd>
            </div>
          </dl>
          <a class="gallery-enter" href="/source-map/">查看来源地图</a>
        </div>
      </section>

      <ArchiveTable objects={objects} />
      <SourceIndex sources={sources} objects={objects} />
      <Lightbox />
      <footer class="site-footer" aria-label="Project links">
        <p>Who Holds the Camera? / V1.9 Custom Domain Activation</p>
        <nav>
          <a href="https://camera.conanxin.com/" target="_blank" rel="noreferrer">Live Demo</a>
          <a href="https://github.com/conanxin/who-holds-the-camera" target="_blank" rel="noreferrer">GitHub Repo</a>
        </nav>
      </footer>
    </div>
  </main>
</BaseLayout>
