---
import ArchiveTable from "@components/ArchiveTable.astro";
import CuratorStatement from "@components/CuratorStatement.astro";
import ExhibitionEntrance from "@components/ExhibitionEntrance.astro";
import GalleryMap from "@components/GalleryMap.astro";
import GalleryRoom from "@components/GalleryRoom.astro";
import SourceIndex from "@components/SourceIndex.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { exhibition, galleries } from "@data/exhibition";
import { objects } from "@data/objects";
import { sources } from "@data/sources";

const heroObjects = objects.filter((object) => object.imagePolicy === "embed").slice(0, 7);
const objectsByGallery = galleries.map((gallery) => ({
  gallery,
  objects: objects.filter((object) => object.galleryId === gallery.id)
}));
---

<BaseLayout title={`${exhibition.titleZh} | ${exhibition.titleEn}`} description={exhibition.statement}>
  <main>
    <ExhibitionEntrance heroObjects={heroObjects} />
    <div class="page-shell">
      <CuratorStatement />
      <GalleryMap galleries={galleries} />
      {objectsByGallery.map(({ gallery, objects }) => <GalleryRoom gallery={gallery} objects={objects} />)}

      <section class="reflection-room" id="reflection-room" aria-labelledby="reflection-title">
        <div class="section-heading">
          <p class="section-kicker">Reflection Room / 谁拿着相机？</p>
          <h2 id="reflection-title">镜头不是一个透明孔洞</h2>
        </div>
        <div class="reflection-room__panel">
          <p class="reflection-room__lead">这间房间没有更多图像。它只留下一个问题：谁拿着相机？</p>
          <div class="reflection-room__grid">
            <p>
              当我们问“谁拿着相机”，并不是要把某位摄影师简单地放在审判席上。更重要的是看见一整套图像条件：旅行路线、出版市场、殖民城市、馆藏制度、技术门槛、版权边界，以及被拍摄者是否有机会回看、命名和保存自己的影像。
            </p>
            <p>
              因此，本展把每一张图像都拆成两层：一层是画面，另一层是 source trail。画面让我们停下；来源路径让我们继续追问。照片中的沉默部分，和可见部分同样重要。
            </p>
          </div>
          <blockquote>
            这张图像记录的不是全部现实，而是一次观看的条件。
          </blockquote>
        </div>
      </section>

      <ArchiveTable objects={objects} />
      <SourceIndex sources={sources} objects={objects} />
    </div>
  </main>
</BaseLayout>
