<div class="lightbox" data-lightbox hidden>
  <div class="lightbox__backdrop" data-lightbox-close></div>
  <section class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox__close" type="button" data-lightbox-close aria-label="Close">Close</button>
    <div class="lightbox__media">
      <img data-lightbox-image src="" alt="" />
    </div>
    <div class="lightbox__label">
      <p class="section-kicker">Close Looking / 近看</p>
      <h2 data-lightbox-title></h2>
      <p data-lightbox-caption></p>
      <dl class="source-trail">
        <div>
          <dt>Credit</dt>
          <dd data-lightbox-credit></dd>
        </div>
        <div>
          <dt>Source</dt>
          <dd><a data-lightbox-source href="#" target="_blank" rel="noreferrer">查看来源</a></dd>
        </div>
        <div>
          <dt>Rights</dt>
          <dd data-lightbox-rights></dd>
        </div>
        <div>
          <dt>Note</dt>
          <dd data-lightbox-note></dd>
        </div>
      </dl>
    </div>
  </section>
</div>

<script>
  const lightbox = document.querySelector("[data-lightbox]");
  const image = document.querySelector("[data-lightbox-image]");
  const title = document.querySelector("[data-lightbox-title]");
  const caption = document.querySelector("[data-lightbox-caption]");
  const credit = document.querySelector("[data-lightbox-credit]");
  const source = document.querySelector("[data-lightbox-source]");
  const rights = document.querySelector("[data-lightbox-rights]");
  const note = document.querySelector("[data-lightbox-note]");
  const triggers = Array.from(document.querySelectorAll(".js-lightbox-trigger"));
  const closers = Array.from(document.querySelectorAll("[data-lightbox-close]"));

  function setText(node, value) {
    if (node instanceof HTMLElement) {
      node.textContent = value || "";
    }
  }

  function openLightbox(trigger) {
    if (!(lightbox instanceof HTMLElement) || !(image instanceof HTMLImageElement)) return;
    image.src = trigger.dataset.src || "";
    image.alt = trigger.dataset.alt || "";
    setText(title, trigger.dataset.title);
    setText(caption, trigger.dataset.caption);
    setText(credit, trigger.dataset.credit);
    setText(rights, trigger.dataset.rights);
    setText(note, trigger.dataset.note);
    if (source instanceof HTMLAnchorElement) {
      source.href = trigger.dataset.source || "#";
    }
    lightbox.hidden = false;
    document.body.classList.add("has-lightbox");
  }

  function closeLightbox() {
    if (!(lightbox instanceof HTMLElement) || !(image instanceof HTMLImageElement)) return;
    lightbox.hidden = true;
    image.removeAttribute("src");
    document.body.classList.remove("has-lightbox");
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      if (trigger instanceof HTMLElement) {
        openLightbox(trigger);
      }
    });
  });

  closers.forEach((closer) => closer.addEventListener("click", closeLightbox));
  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeLightbox();
    }
  });
</script>
