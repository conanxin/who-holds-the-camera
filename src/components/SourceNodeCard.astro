---
import type { SourceNode } from "@data/sourceMap";

interface Props {
  node: SourceNode;
}

const { node } = Astro.props;
---

<article class="source-node-card">
  <div class="source-node-card__topline">
    <p>{node.sourceType}</p>
    <span>{node.relatedObjectIds.length} objects</span>
  </div>
  <h3><a href={node.url} target="_blank" rel="noreferrer">{node.label}</a></h3>
  <p>{node.descriptionZh}</p>
  <dl>
    <div>
      <dt>Use</dt>
      <dd>{node.usedFor}</dd>
    </div>
    <div>
      <dt>Reliability</dt>
      <dd>{node.reliabilityNote}</dd>
    </div>
  </dl>
</article>
