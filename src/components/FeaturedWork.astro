---
import { getObjectPrimaryMedia, type ExhibitionObject } from "@data/objects";

interface Props {
  object: ExhibitionObject;
  eyebrow?: string;
}

const { object, eyebrow = "Featured Work" } = Astro.props;
const media = getObjectPrimaryMedia(object);
const sourceHref = object.originalArchiveUrl || object.sourceUrl;
const isLinkedPreview = media?.role === "linkedPreview";
const sourceLabel = object.sourceId === "blue-lotus" || object.sourceId === "greg-girard" || object.sourceId === "city-darkness" || object.sourceId === "nowicki" || object.sourceId === "fan-ho-estate"
  ? "查看项目页"
  : "查看来源";
const archiveLabel = object.originalArchiveUrl === object.sourceUrl ? "查看原始记录" : "查看馆藏";
const statusClass = object.status.replace(/\s+/g, "-");
const statusLabel: Record<ExhibitionObject["status"], string> = {
  "verified archive source": "Verified archive source",
  "secondary source only": "Secondary source only",
  "rights unclear": "Rights unclear",
  "placeholder pending replacement": "Placeholder pending replacement"
};
---

<article class="featured-work" id={`featured-${object.id}`}>
  <div class="featured-work__media">
    {
      media ? (
        <button
          class="media-button js-lightbox-trigger"
          type="button"
          data-src={media.src}
          data-alt={media.alt}
          data-title={`${object.title} / ${object.titleEn}`}
          data-caption={media.caption || object.captionZh}
          data-credit={media.credit || object.credit}
          data-source={sourceHref}
          data-rights={object.rightsNote}
          data-note={object.curatorialNote}
          aria-label={`查看大图：${object.title}`}
        >
          <img src={media.src} alt={media.alt} loading="lazy" />
          {isLinkedPreview && <span class="media-badge">Linked source only</span>}
        </button>
      ) : (
        <a class="object-card__placeholder" href={sourceHref} target="_blank" rel="noreferrer">
          <span>Linked source only</span>
          <strong>{object.credit}</strong>
        </a>
      )
    }
  </div>
  <div class="featured-work__label">
    <p class="section-kicker">{eyebrow}</p>
    <div class="object-card__topline">
      <p class="object-card__number">{object.displayNumber}</p>
      <span class={`status-badge status-badge--${statusClass}`}>{statusLabel[object.status]}</span>
    </div>
    <h3>{object.title}</h3>
    <p class="object-card__title-en">{object.titleEn}</p>
    <p class="object-card__facts">{object.creator}, {object.year}<br />{object.place} / {object.medium}</p>
    <p class="object-card__caption">{object.captionZh}</p>
    <p class="object-card__note">{object.curatorialNote}</p>
    <div class="featured-work__links">
      <a href={object.sourceUrl} target="_blank" rel="noreferrer">{sourceLabel}</a>
      <a href={sourceHref} target="_blank" rel="noreferrer">{archiveLabel}</a>
    </div>
  </div>
</article>
