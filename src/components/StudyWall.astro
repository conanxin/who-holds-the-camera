---
import type { ExhibitionObject } from "@data/objects";
import ObjectGrid from "./ObjectGrid.astro";

interface Props {
  objects: ExhibitionObject[];
}

const { objects } = Astro.props;
const focusPair = objects.slice(0, 2);
const studyObjects = objects.slice(2);
---

<section class="study-wall" aria-label="Study wall">
  {
    focusPair.length > 0 && (
      <div class="focus-pair">
        <div class="section-heading section-heading--compact">
          <p class="section-kicker">Focus Pair / 对读</p>
          <h2>两张图像之间</h2>
        </div>
        <ObjectGrid objects={focusPair} />
      </div>
    )
  }
  {
    studyObjects.length > 0 && (
      <div class="study-wall__grid">
        <div class="section-heading section-heading--compact">
          <p class="section-kicker">Study Wall / 研究墙</p>
          <h2>补充展品</h2>
        </div>
        <ObjectGrid objects={studyObjects} />
      </div>
    )
  }
</section>
